SELLER_DASHBOARD_HOST=0.0.0.0
SELLER_DASHBOARD_PORT=8000
SELLER_DASHBOARD_BASE_PATH=/sell
SELLER_PUBLIC_ALLOWED_ORIGIN=https://auth.example.com
# Admin password for the dashboard. If unset, the dashboard is open to anyone who can reach it.
# Keep the real value in /etc/seller-dashboard/app.env on the Pi, never commit it.
SELLER_ADMIN_PASSWORD=change-me
