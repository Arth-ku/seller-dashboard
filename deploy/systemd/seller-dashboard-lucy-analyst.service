[Unit]
Description=Publish Lucy seller-dashboard analyst insights
After=network-online.target seller-dashboard.service
Wants=network-online.target
RequiresMountsFor=/home/lwarm/apps/seller-dashboard/data

[Service]
Type=oneshot
User=lwarm
WorkingDirectory=/home/lwarm/apps/seller-dashboard
ExecStart=/usr/bin/python3 /home/lwarm/apps/seller-dashboard/scripts/lucy-analyst.py --write --commit --push
